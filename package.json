{
  "name": "vellum",
  "private": true,
  "version": "0.0.0",
  "description": "Self-hostable AI bookkeeper for freelancers and small teams",
  "license": "AGPL-3.0-or-later",
  "author": "Gurgen Yeghiazaryan <gaaegiazaryan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaaegiazaryan/vellum.git"
  },
  "homepage": "https://github.com/gaaegiazaryan/vellum",
  "bugs": "https://github.com/gaaegiazaryan/vellum/issues",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.16.0",
    "@types/node": "^20.16.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.6"
  }
}
