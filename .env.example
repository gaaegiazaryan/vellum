# Vellum environment template. Copy to .env and fill in real values.
# Never commit a real .env; .gitignore covers it.

# Database, shared between web and api.
DATABASE_URL=postgres://vellum:vellum@localhost:5432/vellum

# Auth secret. Encrypts the Auth.js session cookie on the web app and
# is the shared secret the api uses to decrypt the same cookie. Same
# value on both services. Generate with: openssl rand -base64 48
AUTH_SECRET=replace-with-at-least-32-random-bytes-do-not-ship-this

# Public base URL of the web app. Auth.js auto-detects on most hosts;
# set explicitly if your platform sits behind a proxy that does not
# forward Host correctly.
# AUTH_URL=https://example.com

# Public origin of the api when web and api are served from different
# domains. The browser uses this to open the extraction-status
# WebSocket (ADR-0012). Leave unset for same-origin deploys where a
# reverse proxy already routes /socket.io to the api service.
# NEXT_PUBLIC_API_URL=https://api.example.com

# Redis for the BullMQ queue and pub/sub fanout between api replicas.
REDIS_URL=redis://localhost:6379/0

# Api listen port. Defaults to 3001.
# PORT=3001

# Runtime mode. production tightens defaults and switches the log
# transport to plain JSON for log aggregators to ingest.
NODE_ENV=development

# pino level. Defaults to debug in development and info in production.
# LOG_LEVEL=debug

# Object storage driver. filesystem (default) writes to UPLOAD_DIR and
# is fine for local dev; s3 stores receipts in any S3-compatible bucket
# (AWS S3, Cloudflare R2, Backblaze B2, MinIO) and is what a real deploy
# wants (see docs/adr/0008).
STORAGE_DRIVER=filesystem

# Directory the filesystem driver writes uploaded receipts to.
# UPLOAD_DIR=/var/vellum/uploads

# S3 driver config. Required when STORAGE_DRIVER=s3. S3_ENDPOINT is for
# S3-compatible providers (R2, B2, MinIO); leave it unset for AWS S3.
# R2 and MinIO need S3_FORCE_PATH_STYLE=true.
# S3_BUCKET=vellum-receipts
# S3_REGION=auto
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_FORCE_PATH_STYLE=true

# AI extraction provider. Defaults to mock (no API calls). Set
# anthropic with a valid ANTHROPIC_API_KEY or openai with OPENAI_API_KEY
# in production.
EXTRACTION_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional fallback provider (ADR-0015). When set to a different name
# from EXTRACTION_PROVIDER, the worker tries this provider once on
# retryable infra failures of the primary before failing the job.
# Requires the same API key as if it were primary.
# EXTRACTION_FALLBACK_PROVIDER=openai

# Optional system-wide hard cap on AI spend per UTC day. Non-negative
# decimal in USD. When unset, no enforcement runs. POST /extractions
# returns 429 with scope: "system" once the cap is hit and the worker
# stops processing queued jobs until UTC midnight (ADR-0011).
# EXTRACTION_DAILY_BUDGET_USD=5.00

# Optional per-user hard cap on AI spend per UTC day. Layered under
# the system cap: one user that goes over their personal limit does
# not block the others, while the system cap still bounds the
# operator's wallet. 429 carries scope: "user" when this is the cap
# that fires (ADR-0014).
# EXTRACTION_DAILY_BUDGET_PER_USER_USD=1.00

# Commit sha of the api image, surfaced as commitSha on /healthz. Set
# in your image build (e.g., --build-arg GIT_SHA=$(git rev-parse HEAD))
# so deployed builds are identifiable from a curl on /healthz.
# GIT_SHA=

# Confidence cutoff between succeeded and needs_review extraction
# rows. Decimal between 0 and 1; defaults to 0.7. Raise to be more
# conservative (more receipts land in the review queue); lower to
# auto-confirm more aggressively. ADR-0005.
# EXTRACTION_CONFIDENCE_REVIEW_THRESHOLD=0.7
