{
  "name": "@vellum/api",
  "version": "0.0.0",
  "private": true,
  "description": "Vellum HTTP API. NestJS on Fastify with pino logging",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@vellum/core": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "nestjs-pino": "^4.3.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^20.16.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0"
  }
}
